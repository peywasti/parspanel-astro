---
const quickLinks = [
  { href: "/", label: "خانه" },
  { href: "/about", label: "درباره ما" },
  { href: "/products", label: "محصولات" },
  { href: "/contact", label: "تماس با ما" },
];

const productLinks = [
  { href: "/products/roof-panel", label: "ساندویچ پانل سقفی" },
  { href: "/products/wall-panel", label: "ساندویچ پانل دیواری" },
  { href: "/products/cold-panel", label: "ساندویچ پانل سردخانه" },
  { href: "/products/clean-panel", label: "ساندویچ پانل اتاق تمیز" },
  { href: "/products/eco-panel", label: "ساندویچ پانل اکونومی" },
];
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div
            class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center"
          >
            <svg
              class="w-4 h-4 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
              ></path>
            </svg>
          </div>
          <span class="text-lg font-bold text-white">پارس پانل</span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed mb-4">
          نمایندگی فروش ساندویچ پانل سقفی و دیواری پلی یورتان فولادغرب. تضمین
          کیفیت، قیمت مناسب و تحویل به موقع.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">دسترسی سریع</h3>
        <ul class="space-y-2">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-400 hover:text-brand-400 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">محصولات</h3>
        <ul class="space-y-2">
          {
            productLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-400 hover:text-brand-400 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">اطلاعات تماس</h3>
        <div class="space-y-3 text-sm text-gray-400">
          <p class="flex items-start gap-2">
            <svg
              class="w-5 h-5 text-brand-500 flex-shrink-0 mt-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span
              >تهران - جردن امانیه بلوار گیتی پلاک ۷ ساختمان ساباط واحد ۸</span
            >
          </p>
          <p class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-brand-500 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <span>۰۲۱-۲۲۰۱۰۹۷۱</span>
          </p>
          <p class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-brand-500 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <a
              href="mailto:info@parspanel.com"
              class="hover:text-brand-400 transition-colors"
              >info@parspanel.com</a
            >
          </p>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-800 mt-10 pt-8 text-center">
      <p class="text-sm text-gray-500">
        © ۱۴۰۴ پارس پانل. کلیه حقوق این وب‌سایت برای شرکت نوردکاران فولادغرب
        محفوظ می‌باشد.
      </p>
    </div>
  </div>
</footer>
