---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="ساندویچ پانل اتاق تمیز - پارس پنل" description="ساندویچ پانل مخصوص اتاق‌های تمیز و محیط‌های بهداشتی با استانداردهای ویژه">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-purple-50 to-pink-100 dark:from-slate-800 dark:to-slate-900 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
            ساندویچ پانل اتاق تمیز
          </h1>
          <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
            پانل مخصوص اتاق‌های تمیز و محیط‌های بهداشتی با استانداردهای ویژه و پوشش‌های خاص
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="bg-purple-600 hover:bg-purple-700 text-white px-8 py-4 rounded-lg font-semibold text-lg transition-colors shadow-lg">
              درخواست قیمت
            </a>
            <a href="#specifications" class="border-2 border-purple-600 text-purple-600 hover:bg-purple-600 hover:text-white px-8 py-4 rounded-lg font-semibold text-lg transition-colors">
              مشخصات فنی
            </a>
          </div>
        </div>
        <div class="text-center">
          <img src="/images/products/clean-panel.jpg" alt="ساندویچ پانل اتاق تمیز" class="rounded-lg shadow-xl max-w-full h-auto">
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 dark:text-white mb-12">
        ویژگی‌های ساندویچ پانل اتاق تمیز
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">مقاوم در برابر آلودگی</h3>
          <p class="text-gray-600 dark:text-gray-300">سطح صاف و غیر متخلخل برای محیط‌های پاک</p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">استانداردهای بهداشتی</h3>
          <p class="text-gray-600 dark:text-gray-300">مناسب برای صنایع غذایی و دارویی</p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">عایق حرارتی</h3>
          <p class="text-gray-600 dark:text-gray-300">کنترل دما در محیط‌های حساس</p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-orange-100 dark:bg-orange-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">ضدعفونی آسان</h3>
          <p class="text-gray-600 dark:text-gray-300">پاک‌سازی و ضدعفونی ساده و سریع</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Specifications Section -->
  <section id="specifications" class="py-16 bg-gray-50 dark:bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 dark:text-white mb-12">
        مشخصات فنی
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">مشخصات کلی</h3>
          <div class="space-y-4">
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">عرض مفید</span>
              <span class="font-semibold text-gray-900 dark:text-white">۹۵ سانتی‌متر</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">طول</span>
              <span class="font-semibold text-gray-900 dark:text-white">تا ۱۵ متر</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">ضخامت عایق</span>
              <span class="font-semibold text-gray-900 dark:text-white">۶ تا ۲۰ سانتی‌متر</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">نوع عایق</span>
              <span class="font-semibold text-gray-900 dark:text-white">پلی یورتان / پلی استایرن</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">نوع پوشش</span>
              <span class="font-semibold text-gray-900 dark:text-white">گالوانیزه / آلوزینک</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">کلاس پاکیزگی</span>
              <span class="font-semibold text-gray-900 dark:text-white">ISO 5 تا ISO 8</span>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">کاربردها</h3>
          <ul class="space-y-3 text-gray-600 dark:text-gray-300">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-purple-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              اتاق‌های پاک‌سازی دارویی
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-purple-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              صنایع غذایی و بهداشتی
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-purple-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              آزمایشگاه‌های تحقیقاتی
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-purple-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              اتاق‌های عمل پزشکی
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-purple-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              صنایع الکترونیک و نیمه‌رسانا
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-purple-600 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">برای سفارش و مشاوره فنی</h2>
      <p class="text-xl mb-8 opacity-90">
        کارشناسان ما آماده پاسخگویی به سوالات شما هستند
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-purple-600 hover:bg-gray-100 px-8 py-4 rounded-lg font-semibold text-lg transition-colors shadow-lg">
          درخواست قیمت
        </a>
        <a href="/products" class="border-2 border-white text-white hover:bg-white hover:text-purple-600 px-8 py-4 rounded-lg font-semibold text-lg transition-colors">
          سایر محصولات
        </a>
      </div>
    </div>
  </section>
</Layout>