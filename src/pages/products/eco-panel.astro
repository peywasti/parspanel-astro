---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="ساندویچ پانل اکونومی - پارس پانل" description="ساندویچ پانل تک رو ورق اکونومی با عایق پلی اورتان ۲ سانتی‌متر - مناسب جایگزین ورق سقف شیروانی">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-orange-50 to-amber-100 dark:from-slate-800 dark:to-slate-900 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
            ساندویچ پانل اکونومی
          </h1>
          <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
            ساندویچ پانل تک رو ورق با عایق پلی اورتان ۲ سانتی‌متر، اقتصادی و مقرون به صرفه با ویژگی‌های اصلی ساندویچ پانل
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="bg-orange-600 hover:bg-orange-700 text-white px-8 py-4 rounded-lg font-semibold text-lg transition-colors shadow-lg">
              درخواست قیمت
            </a>
            <a href="#specifications" class="border-2 border-orange-600 text-orange-600 hover:bg-orange-600 hover:text-white px-8 py-4 rounded-lg font-semibold text-lg transition-colors">
              مشخصات فنی
            </a>
          </div>
        </div>
        <div class="text-center">
          <img src="/images/products/eco-panel.jpg" alt="ساندویچ پانل اکونومی" class="rounded-lg shadow-xl max-w-full h-auto" />
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 dark:text-white mb-12">
        ویژگی‌های ساندویچ پانل اکونومی
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-orange-100 dark:bg-orange-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">مقرون به صرفه</h3>
          <p class="text-gray-600 dark:text-gray-300">جایگزین اقتصادی ورق سقف شیروانی</p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">عایق حرارتی</h3>
          <p class="text-gray-600 dark:text-gray-300">عایق ۲ سانتی پلی اورتان</p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">نصب آسان</h3>
          <p class="text-gray-600 dark:text-gray-300">نصب سریع‌تر از ورق زیرسازی‌دار</p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">ورق گالوانیزه رنگی</h3>
          <p class="text-gray-600 dark:text-gray-300">ورق روی رنگی گالوانیزه</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Specifications Section -->
  <section id="specifications" class="py-16 bg-gray-50 dark:bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 dark:text-white mb-12">
        مشخصات فنی
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">مشخصات کلی</h3>
          <div class="space-y-4">
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">نوع ورق روی</span>
              <span class="font-semibold text-gray-900 dark:text-white">رنگی گالوانیزه</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">نوع ورق زیر</span>
              <span class="font-semibold text-gray-900 dark:text-white">کاغذ ضدآب</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">ضخامت عایق</span>
              <span class="font-semibold text-gray-900 dark:text-white">۲ سانتی‌متر پلی اورتان</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">عرض مفید</span>
              <span class="font-semibold text-gray-900 dark:text-white">۹۷ سانتی‌متر</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-200 dark:border-slate-600">
              <span class="text-gray-600 dark:text-gray-300">طول</span>
              <span class="font-semibold text-gray-900 dark:text-white">تا ۱۵ متر</span>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">کاربردها</h3>
          <ul class="space-y-3 text-gray-600 dark:text-gray-300">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-orange-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              سقف شیروانی سوله‌ها
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-orange-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              پوشش سقف انبارها
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-orange-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              سقف کارگاه‌های صنعتی
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-orange-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              سقف سالن‌های کشاورزی
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-orange-500 ml-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              جایگزین ورق پروفایل سقف شیروانی
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-orange-600 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">برای سفارش و مشاوره فنی</h2>
      <p class="text-xl mb-8 opacity-90">
        کارشناسان ما آماده پاسخگویی به سوالات شما هستند
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-orange-600 hover:bg-gray-100 px-8 py-4 rounded-lg font-semibold text-lg transition-colors shadow-lg">
          درخواست قیمت
        </a>
        <a href="/products" class="border-2 border-white text-white hover:bg-white hover:text-orange-600 px-8 py-4 rounded-lg font-semibold text-lg transition-colors">
          سایر محصولات
        </a>
      </div>
    </div>
  </section>
</Layout>
