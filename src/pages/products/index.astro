---
import Layout from '../../layouts/Layout.astro';

const products = [
  {
    title: 'ساندویچ پانل سقفی',
    description: 'پانل سقفی با کیفیت بالا برای پوشش سقف سالن‌های صنعتی و کشاورزی با عایق حرارتی و صوتی برتر',
    href: '/products/roof-panel',
    image: '/images/products/roof-panel.jpg',
    color: 'blue',
  },
  {
    title: 'ساندویچ پانل دیواری',
    description: 'پانل دیواری مقاوم برای دیوارهای داخلی و خارجی سالن‌های صنعتی با عایق حرارتی و صوتی عالی',
    href: '/products/wall-panel',
    image: '/images/products/wall-panel.jpg',
    color: 'green',
  },
  {
    title: 'ساندویچ پانل سردخانه',
    description: 'پانل مخصوص سردخانه با عایق حرارتی بالا برای نگهداری مواد غذایی، دارویی و صنعتی',
    href: '/products/cold-panel',
    image: '/images/products/cold-panel.jpg',
    color: 'cyan',
  },
  {
    title: 'ساندویچ پانل اتاق تمیز',
    description: 'پانل مخصوص اتاق‌های تمیز و محیط‌های بهداشتی با استانداردهای ویژه و پوشش‌های خاص',
    href: '/products/clean-panel',
    image: '/images/products/clean-panel.jpg',
    color: 'purple',
  },
  {
    title: 'ساندویچ پانل اکونومی',
    description: 'پانل تک رو ورق با عایق پلی اورتان ۲ سانتی‌متر، اقتصادی و مقرون به صرفه',
    href: '/products/eco-panel',
    image: '/images/products/eco-panel.jpg',
    color: 'orange',
  },
];

const colorClasses: Record<string, { bg: string; text: string; hover: string; ring: string }> = {
  blue: { bg: 'bg-blue-100 dark:bg-blue-900', text: 'text-blue-600 dark:text-blue-400', hover: 'hover:bg-blue-600', ring: 'focus:ring-blue-500' },
  green: { bg: 'bg-green-100 dark:bg-green-900', text: 'text-green-600 dark:text-green-400', hover: 'hover:bg-green-600', ring: 'focus:ring-green-500' },
  cyan: { bg: 'bg-cyan-100 dark:bg-cyan-900', text: 'text-cyan-600 dark:text-cyan-400', hover: 'hover:bg-cyan-600', ring: 'focus:ring-cyan-500' },
  purple: { bg: 'bg-purple-100 dark:bg-purple-900', text: 'text-purple-600 dark:text-purple-400', hover: 'hover:bg-purple-600', ring: 'focus:ring-purple-500' },
  orange: { bg: 'bg-orange-100 dark:bg-orange-900', text: 'text-orange-600 dark:text-orange-400', hover: 'hover:bg-orange-600', ring: 'focus:ring-orange-500' },
};
---

<Layout title="محصولات پارس پانل" description="لیست محصولات پارس پانل - فروش انواع ساندویچ پانل سقفی، دیواری، سردخانه، اتاق تمیز و اکونومی">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-50 to-blue-100 dark:from-slate-800 dark:to-slate-900 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        محصولات پارس پانل
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
        بررسی و انتخاب انواع ساندویچ پانل متناسب با نیاز پروژه شما
      </p>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="py-16 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product) => {
          const c = colorClasses[product.color];
          return (
            <article class="group bg-white dark:bg-slate-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 dark:border-slate-700">
              <a href={product.href} class="block">
                <div class="aspect-video bg-gray-100 dark:bg-slate-700 overflow-hidden">
                  <img
                    src={product.image}
                    alt={product.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
                <div class="p-6">
                  <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                    {product.title}
                  </h2>
                  <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-4">
                    {product.description}
                  </p>
                  <span class={`inline-flex items-center gap-1 text-sm font-semibold ${c.text} group-hover:underline`}>
                    مشاهده جزئیات
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                  </span>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gray-50 dark:bg-slate-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
        نیاز به مشاوره دارید؟
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-300 mb-8">
        کارشناسان فنی پارس پانل آماده راهنمایی شما در انتخاب بهترین محصول هستند.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-colors shadow-lg hover:shadow-xl">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        تماس با کارشناسان
      </a>
    </div>
  </section>
</Layout>
